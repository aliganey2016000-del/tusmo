datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. Habaynta Isticmaalayaasha (User Model)
// ==========================================
model User {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  username   String   @unique
  email      String   @unique
  password   String
  role       Role     @default(STUDENT)
  isApproved Boolean  @default(false)
  
  student    Student? @relation(fields: [studentId], references: [id])
  studentId  String?  @unique
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  teacherId  String?  @unique

  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

// ==========================================
// 2. Habaynta Ardayda (Student Model)
// ==========================================
model Student {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  grade           String   
  gender          String   @default("Male")
  phone           String?
  parentName      String?
  parentPhone     String?
  status          String   @default("Active")
  rejectionReason String?  
  
  class           Class?   @relation(fields: [classId], references: [id])
  classId         String?
  
  user            User?
  attendance      Attendance[]
  results         Result[]
  createdAt       DateTime @default(now())

  @@index([name])
  @@index([classId])
  @@index([status])
}

// ==========================================
// 3. Habaynta Macallimiinta (Teacher Model)
// ==========================================
model Teacher {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  subject   String   // Waxay kaydinaysaa maadooyinka (JSON String ahaan)
  phone     String
  status    String   @default("Active")
  
  classes   Class[]  
  attendance Attendance[] 

  user      User?
  createdAt DateTime @default(now())

  @@index([name])
}

// ==========================================
// 4. Habaynta Fasallada (Class Model)
// ==========================================
enum EducationLevel {
  Primary
  Middle
  Secondary
}

enum Shift {
  Morning
  Afternoon
  Evening
}

model Class {
  id        String         @id @default(cuid())
  name      String         
  room      String
  capacity  Int            
  
  // Waxaan ku darnay @default si database-ku u oggolaado xogta hore u jirtay
  level     EducationLevel @default(Primary)
  shift     Shift          @default(Morning)

  students  Student[]      
  teachers  Teacher[]      

  attendance Attendance[]

  createdAt DateTime @default(now())
  // updatedAt isagana sii qiimo bilow ah si looga fogaado khaladka push-ka
  updatedAt DateTime @default(now()) @updatedAt

  @@index([name])
  @@index([level])
  @@index([shift])
}

// ==========================================
// 5. Habaynta Xaadiriska (Attendance Model)
// ==========================================
model Attendance {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  status    String   
  subject   String   
  
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  teacherId String

  student   Student  @relation(fields: [studentId], references: [id])
  studentId String
  
  class     Class    @relation(fields: [classId], references: [id])
  classId   String

  @@index([date])
  @@index([classId])
  @@index([studentId])
}

// ==========================================
// 6. Habaynta Natiijooyinka (Result Model)
// ==========================================
model Result {
  id        String   @id @default(cuid())
  subject   String
  score     Float
  grade     String   
  
  student   Student  @relation(fields: [studentId], references: [id])
  studentId String
}

// ==========================================
// 7. Fariimaha (Contact Messages)
// ==========================================
model ContactMessage {
  id        String        @id @default(cuid())
  name      String        
  email     String        
  subject   String        
  message   String        @db.Text 
  status    MessageStatus @default(UNREAD) 
  createdAt DateTime      @default(now())
}

enum MessageStatus {
  UNREAD    
  READ      
  REPLIED   
}

// ==========================================
// 8. Codsiyada Macallimiinta (Applications)
// ==========================================
model InstructorApplication {
  id          String            @id @default(cuid())
  fullName    String            
  email       String            @unique
  phone       String?
  specialty   String            
  experience  String?           
  bio         String?           @db.Text 
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
}

enum ApplicationStatus {
  PENDING   
  APPROVED  
  REJECTED  
}