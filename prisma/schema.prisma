datasource db {
  provider  = "postgresql" // SQLite ka dhig postgresql
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Khadkan waa muhiim si Supabase ugu xirmo
}

generator client {
  provider = "prisma-client-js"
}

// 1. User Model (Authentication-ka)
model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  
  // Xiriirka uu la leeyahay Student ama Teacher (Optional)
  student   Student? @relation(fields: [studentId], references: [id])
  studentId String?  @unique
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  teacherId String?  @unique

  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

// 2. Student Model
model Student {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  grade         String   
  gender        String   @default("Male")
  phone         String?
  parentName    String?
  parentPhone   String?
  status        String   @default("Active")
  
  class         Class?   @relation(fields: [classId], references: [id])
  classId       String?
  
  user          User?
  attendance    Attendance[]
  results       Result[]
  createdAt     DateTime @default(now())
}

// 3. Teacher Model
model Teacher {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  subject   String
  phone     String
  status    String   @default("Active")
  
  classes   Class[] 
  user      User?

  createdAt DateTime @default(now())
}

// 4. Class Model
model Class {
  id        String    @id @default(cuid())
  name      String    
  room      String
  capacity  Int
  
  students  Student[]
  
  teacher   Teacher?  @relation(fields: [teacherId], references: [id])
  teacherId String?

  attendance Attendance[]
}

// 5. Attendance Model
model Attendance {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  status    String   
  
  student   Student  @relation(fields: [studentId], references: [id])
  studentId String
  
  class     Class    @relation(fields: [classId], references: [id])
  classId   String
}

// 6. Result Model
model Result {
  id        String   @id @default(cuid())
  subject   String
  score     Float
  grade     String   
  
  student   Student  @relation(fields: [studentId], references: [id])
  studentId String
}