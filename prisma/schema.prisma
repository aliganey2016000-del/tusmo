datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. User Model (Authentication-ka)
model User {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  username   String   @unique
  email      String   @unique
  password   String
  role       Role     @default(STUDENT)
  isApproved Boolean  @default(false)
  
  // Xiriirka uu la leeyahay Student ama Teacher
  student    Student? @relation(fields: [studentId], references: [id])
  studentId  String?  @unique
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  teacherId  String?  @unique

  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

// 2. Student Model
model Student {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  grade           String   
  gender          String   @default("Male")
  phone           String?
  parentName      String?
  parentPhone     String?
  status          String   @default("Active")
  rejectionReason String?  // TANI AYAA CUSUB: Waxay keydinaysaa sababta diidmada
  
  class           Class?   @relation(fields: [classId], references: [id])
  classId         String?
  
  user            User?
  attendance      Attendance[]
  results         Result[]
  createdAt       DateTime @default(now())
}


// 3. Teacher Model
model Teacher {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  subject   String
  phone     String
  status    String   @default("Active")
  
  classes   Class[]  // Macallinku fasallo badan ayuu dhigi karaa
  
  // KAN AYAA KU CUSUB: 
  // Wuxuu kuu oggolaanayaa inaad ogaato macallin kasta inta cashar ee uu attendance ka qaaday
  attendance Attendance[] 

  user      User?
  createdAt DateTime @default(now())
}

// 4. Class Model
model Class {
  id        String    @id @default(cuid())
  name      String    
  room      String
  capacity  Int
  
  students  Student[]
  teachers  Teacher[] 

  attendance Attendance[]
}

// 5. Attendance Model (Halkan ayaa ah wadnaha logigga cusub)
model Attendance {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  status    String   // Present, Absent, Late
  
  // LABADAN AYAA KA MAQAN DATABASE-KAAGA:
  subject   String   
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])

  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
}


// 6. Result Model
model Result {
  id        String   @id @default(cuid())
  subject   String
  score     Float
  grade     String   
  
  student   Student  @relation(fields: [studentId], references: [id])
  studentId String
}



// 7. Model-ka Fariimaha (Contact Us Messages)
// Waxaan u habeeyay sidii foomka sawirka ku jira (Magaca, Email, Ujeedada, Fariinta)
model ContactMessage {
  id        String        @id @default(cuid())
  name      String        // Magacaaga
  email     String        // Email-kaaga
  subject   String        // Ujeedada
  message   String        @db.Text // Fariintaada
  status    MessageStatus @default(UNREAD) // In la akhriyay iyo in kale
  createdAt DateTime      @default(now())
}

enum MessageStatus {
  UNREAD    // Cusub (Lama akhrin)
  READ      // La akhriyay
  REPLIED   // Laga jawaabay
}

// 8. Model-ka Codsiyada Macallimiinta (Instructor Applications)
// Waxaa loo isticmaalayaa bogga "Become an Instructor"
model InstructorApplication {
  id          String            @id @default(cuid())
  fullName    String            // Magaca oo buuxa
  email       String            @unique
  phone       String?
  specialty   String            // Maadada uu ku takhasusay (Subject)
  experience  String?           // Khibraddiisa (Years of experience)
  bio         String?           @db.Text // Sharaxaad kooban oo isaga ku saabsan
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
}

enum ApplicationStatus {
  PENDING   // Sugitaan
  APPROVED  // La aqbalay
  REJECTED  // La diiday
}